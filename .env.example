# ─────────────────────────────────────────────────────────────────
#  AI-POWERED SURVEILLANCE INTELLIGENCE PLATFORM
#  Environment Configuration — Copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-256-bit-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL / TimescaleDB ──────────────────────────────────────
POSTGRES_USER=asip
POSTGRES_PASSWORD=asip_secret
POSTGRES_DB=surveillance

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_USER=asip
MONGO_PASSWORD=asip_secret
MONGO_DB=surveillance

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=asip_redis

# ── LLM Providers ─────────────────────────────────────────────────
# Ollama (default — runs locally, no API key needed)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# OpenAI (optional — if set, OpenAIProvider is used instead of Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Computer Vision ───────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.45
FACE_RECOGNITION_THRESHOLD=0.65
MAX_TRAJECTORY_LENGTH=120

# ── Storage ───────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
REPORTS_DIR=/app/reports
MAX_UPLOAD_SIZE_MB=500

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
